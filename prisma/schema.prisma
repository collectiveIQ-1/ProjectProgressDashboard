generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider = "postgresql"
}
 
model Progress {
  id              Int              @id @default(autoincrement())
  process         String           @unique
  data            Json             @default("{}")
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  meeting_updates MeetingUpdate[]
  milestones      Milestone[]
 
  @@map("progress")
}
 
model MeetingUpdate {
  id          Int      @id @default(autoincrement())
  progress_id Int
  progress    Progress @relation(fields: [progress_id], references: [id], onDelete: Cascade)
  date        String
  time        String
  note        String
  is_done     Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
 
  @@map("meeting_updates")
}
 
model Milestone {
  id          Int      @id @default(autoincrement())
  progress_id Int
  progress    Progress @relation(fields: [progress_id], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  due_date    String?
  status      String   @default("Pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
 
  @@map("milestones")
}