generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Progress {
  id                Int               @id @default(autoincrement())
  process           String            @unique
  data              Json              @default("{}")
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  type              String?
  status            String?
  completion        Decimal?          @default(0) @db.Decimal(5, 4)
  doc               Decimal?          @default(0) @db.Decimal(5, 4)
  people            String[]
  dept              String?
  priority          String?
  start_date        String?
  deadline          String?
  frequency         String?
  auto_fte          Decimal?          @db.Decimal(10, 4)
  manual_fte        Decimal?          @db.Decimal(10, 4)
  last_run_date     String?
  last_run_count    Int?
  purpose           String?
  expected_results  String?
  beta_testing_date String?
  assign_team       String?
  tags              String[]
  bug_fixes         bug_fixes[]
  change_requests   change_requests[]
  feature_addons    feature_addons[]
  meeting_updates   MeetingUpdate[]
  milestones        Milestone[]
  requirements      requirements[]
  run_dates         run_dates[]

  @@map("progress")
}

model MeetingUpdate {
  id          Int      @id @default(autoincrement())
  progress_id Int
  date        String
  time        String
  note        String
  is_done     Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  progress    Progress @relation(fields: [progress_id], references: [id], onDelete: Cascade)

  @@index([progress_id], map: "idx_meeting_updates_progress_id")
  @@map("meeting_updates")
}

model Milestone {
  id          Int      @id @default(autoincrement())
  progress_id Int
  title       String
  description String   @default("")
  due_date    String?
  status      String   @default("Pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  progress    Progress @relation(fields: [progress_id], references: [id], onDelete: Cascade)

  @@index([progress_id], map: "idx_milestones_progress_id")
  @@map("milestones")
}

model change_requests {
  id          Int       @id @default(autoincrement())
  progress_id Int
  title       String
  description String?   @default("")
  priority    String?   @default("Medium")
  status      String?   @default("Pending")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  progress    Progress  @relation(fields: [progress_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([progress_id], map: "idx_change_requests_progress_id")
}

model credentials {
  id         Int       @id @default(autoincrement())
  username   String    @unique
  password   String
  role       String    @default("Member")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model feature_addons {
  id          Int       @id @default(autoincrement())
  progress_id Int
  title       String
  description String?   @default("")
  priority    String?   @default("Medium")
  status      String?   @default("Requested")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  progress    Progress  @relation(fields: [progress_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([progress_id], map: "idx_feature_addons_progress_id")
}

model requirements {
  id          Int       @id @default(autoincrement())
  progress_id Int
  title       String
  description String?   @default("")
  priority    String?   @default("Medium")
  status      String?   @default("Open")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  progress    Progress  @relation(fields: [progress_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([progress_id], map: "idx_requirements_progress_id")
}

model bug_fixes {
  id          Int       @id @default(autoincrement())
  progress_id Int
  title       String
  description String?   @default("")
  priority    String?   @default("Medium")
  status      String?   @default("Open")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  progress    Progress  @relation(fields: [progress_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([progress_id], map: "idx_bug_fixes_progress_id")
}

model run_dates {
  id          Int       @id @default(autoincrement())
  progress_id Int
  run_date    String
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  progress    Progress  @relation(fields: [progress_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([progress_id, run_date], map: "idx_run_dates_unique")
  @@index([progress_id], map: "idx_run_dates_progress_id")
}
