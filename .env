# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:123@localhost:5432/Progressdashboard"

# Individual PG variables used by server.js (pg Pool)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=Progressdashboard
PG_USER=postgres
PG_PASSWORD=123

# Server port
PORT=3000
